# ============================================================================
# ScenicPathFinder Environment Variables
# ============================================================================
# Docker Compose will automatically load .env
# ============================================================================

# PostGIS / Martin Configuration
POSTGRES_USER=scenic
POSTGRES_PASSWORD=
POSTGRES_DB=scenic_tiles

# Flask Configuration
FLASK_ENV=development
SECRET_KEY=change-me-in-production

# Async Pipeline Configuration
ASYNC_MODE=true
TASK_LOCK_TIMEOUT=900

# Redis/Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Processing Modes
# Options for GREENNESS_MODE: OFF, FAST, EDGE_SAMPLING, NOVACK
GREENNESS_MODE=EDGE_SAMPLING

# Options for ELEVATION_MODE: OFF, API, LOCAL
ELEVATION_MODE=LOCAL

# Options for WATER_MODE: OFF, FAST
WATER_MODE=FAST

# Options for SOCIAL_MODE: OFF, FAST
SOCIAL_MODE=FAST

# Options for NORMALISATION_MODE: STATIC, DYNAMIC
NORMALISATION_MODE=DYNAMIC

# Options for COST_FUNCTION: WSM_ADDITIVE, HYBRID_DISJUNCTIVE
COST_FUNCTION=HYBRID_DISJUNCTIVE
